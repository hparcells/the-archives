{
  "name": "the-archives",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8000",
    "dev:secrets": "infisical run --env=dev -- npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "cypress run --e2e && cypress run --component",
    "docker:build": "docker build -t ghcr.io/hparcells/the-archives:latest .",
    "docker:push": "docker push ghcr.io/hparcells/the-archives:latest",
    "docker:deploy": "npm run docker:build && npm run docker:push",
    "prepare": "husky"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.6",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "cypress": "^15.15.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
